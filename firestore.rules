rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global safety net: default-deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper Functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() &&
        (exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
          (request.auth.token.email == "mdalaminsifat2022@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidId(id) {
      return id is string && id.size() <= 128;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Domain Validators
    function isValidStory(data) {
      return data.keys().hasAll(['title', 'lastModified', 'ownerId']) &&
             data.title is string && data.title.size() <= 200 &&
             (!('subtitle' in data) || (data.subtitle is string && data.subtitle.size() <= 200)) &&
             data.lastModified is number &&
             data.ownerId is string &&
             (!('summary' in data) || (data.summary is string && data.summary.size() <= 6000)) &&
             (!('isDeleted' in data) || data.isDeleted is bool) &&
             (!('isPublished' in data) || data.isPublished is bool) &&
             (!('isPinned' in data) || data.isPinned is bool) &&
             (!('genres' in data) || data.genres is list) &&
             (!('chapters' in data) || data.chapters is list) &&
             (!('characters' in data) || data.characters is list) &&
             (!('creatures' in data) || data.creatures is list) &&
             (!('locations' in data) || data.locations is list) &&
             (!('factions' in data) || data.factions is list) &&
             (!('skills' in data) || data.skills is list) &&
             (!('weapons' in data) || data.weapons is list);
    }

    // Connection check document - must be public for the check to work
    match /test/connection {
      allow read: if true;
    }

    match /users/{userId} {
      allow read: if isSignedIn() && (isOwner(userId) || isAdmin());
      // Admin collection for role lookups
      match /private/{document=**} {
        allow read, write: if isAdmin();
      }
    }
    
    match /admins/{userId} {
      allow read: if isSignedIn();
    }

    match /stories/{storyId} {
      // Allow listing published stories for everyone, or all for owner/admin
      allow list: if (resource.data.isPublished == true) || isSignedIn();
      
      // Get: public stories or owner
      allow get: if (resource.data.isPublished == true) || isOwner(resource.data.ownerId) || isAdmin();
      
      allow create: if isSignedIn() && 
                      isValidStory(incoming()) && 
                      isOwner(incoming().ownerId);
                      
      allow update: if (isSignedIn() && (isOwner(existing().ownerId) || isAdmin()) && isValidStory(incoming()) && incoming().ownerId == existing().ownerId) ||
                      (existing().isPublished == true && 
                       incoming().diff(existing()).affectedKeys().hasOnly(['chapters']) &&
                       isValidStory(incoming()));
                      
      allow delete: if isSignedIn() && (isOwner(existing().ownerId) || isAdmin());
    }
  }
}
