rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global safety net: default-deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper Functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() &&
        (exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
          (request.auth.token.email == "mdalaminsifat2022@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidId(id) {
      return id is string && id.size() <= 128;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Domain Validators
    function isValidStory(data) {
      return data.keys().hasAll(['title', 'lastModified', 'ownerId']) &&
             data.title is string && data.title.size() <= 200 &&
             (!('subtitle' in data) || (data.subtitle is string && data.subtitle.size() <= 200)) &&
             data.lastModified is number &&
             data.ownerId is string &&
             (!('summary' in data) || (data.summary is string && data.summary.size() <= 6000)) &&
             (!('isDeleted' in data) || data.isDeleted is bool) &&
             (!('isPublished' in data) || data.isPublished is bool) &&
             (!('isPinned' in data) || data.isPinned is bool) &&
             (!('genres' in data) || data.genres is list) &&
             (!('chapters' in data) || data.chapters is list) &&
             (!('characters' in data) || data.characters is list) &&
             (!('creatures' in data) || data.creatures is list) &&
             (!('locations' in data) || data.locations is list) &&
             (!('factions' in data) || data.factions is list) &&
             (!('skills' in data) || data.skills is list) &&
             (!('weapons' in data) || data.weapons is list) &&
             (!('imageUrl' in data) || (data.imageUrl is string && data.imageUrl.size() <= 2000));
    }

    // Connection check document - must be public for the check to work
    match /test/connection {
      allow read: if true;
    }

    match /users/{userId} {
      allow read: if isSignedIn() && (isOwner(userId) || isAdmin());
      // Admin collection for role lookups
      match /private/{document=**} {
        allow read, write: if isAdmin();
      }
    }
    
    match /admins/{userId} {
      allow read: if isSignedIn();
    }

    match /stories/{storyId} {
      // Allow listing published and non-deleted stories for everyone
      allow list: if (resource.data.get('isPublished', false) == true && resource.data.get('isDeleted', false) == false) || isSignedIn();
      
      // Get: public stories or owner
      allow get: if (resource.data.get('isPublished', false) == true && resource.data.get('isDeleted', false) == false) || isOwner(resource.data.get('ownerId', '')) || isAdmin();
      
      allow create: if isSignedIn() && 
                      isValidStory(incoming()) && 
                      isOwner(incoming().ownerId);
                      
      allow update: if (isSignedIn() && (isOwner(existing().get('ownerId', '')) || isAdmin()) && isValidStory(incoming()) && incoming().get('ownerId', '') == existing().get('ownerId', '')) ||
                      (existing().get('isPublished', false) == true && 
                       incoming().diff(existing()).affectedKeys().hasOnly(['chapters', 'stats']) &&
                       isValidStory(incoming()));
                      
      allow delete: if isSignedIn() && (isOwner(existing().get('ownerId', '')) || isAdmin());
    }

    function isValidSuggestion(data) {
      return data.keys().hasAll(['storyId', 'storyOwnerId', 'chapterId', 'readerId', 'selectedText', 'suggestedText', 'status', 'createdAt']) &&
             data.storyId is string &&
             data.storyOwnerId is string &&
             data.chapterId is string &&
             data.readerId is string &&
             data.selectedText is string && data.selectedText.size() <= 2000 &&
             data.suggestedText is string && data.suggestedText.size() <= 6000 &&
             data.status in ['pending', 'accepted', 'dismissed'] &&
             data.createdAt is number;
    }

    match /suggestions/{suggestionId} {
      allow read: if isSignedIn() && (
        isOwner(resource.data.get('readerId', '')) || 
        isOwner(resource.data.get('storyOwnerId', '')) ||
        isAdmin()
      );
      
      allow create: if isSignedIn() && 
                      isValidSuggestion(incoming()) && 
                      isOwner(incoming().readerId);
                      
      allow update: if isSignedIn() && (
        // Master can change status
        (isOwner(existing().get('storyOwnerId', '')) && 
         incoming().diff(existing()).affectedKeys().hasOnly(['status', 'resolvedAt']) &&
         isValidSuggestion(incoming())) 
        ||
        // Reader can edit their own (if still pending)
        (isOwner(existing().get('readerId', '')) && existing().get('status', '') == 'pending' && isValidSuggestion(incoming()) && incoming().status == 'pending')
        ||
        isAdmin()
      );
      
      allow delete: if isSignedIn() && (isOwner(existing().get('readerId', '')) || isAdmin());
    }
  }
}
