{
  "entities": {
    "Story": {
      "title": "Story",
      "description": "A novel or story containing chapters, characters, and other metadata.",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "The title of the novel." },
        "subtitle": { "type": "string", "description": "The subtitle of the novel." },
        "genres": { "type": "array", "items": { "type": "string" } },
        "lastModified": { "type": "number", "description": "Timestamp of the last modification." },
        "characters": { 
          "type": "array", 
          "items": { "$ref": "Character" },
          "description": "List of characters in the story."
        },
        "chapters": { 
          "type": "array", 
          "items": { "$ref": "Chapter" },
          "description": "List of chapters in the story."
        },
        "creatures": { 
          "type": "array", 
          "items": { "$ref": "Creature" }
        },
        "locations": { 
          "type": "array", 
          "items": { "$ref": "Location" }
        },
        "factions": { 
          "type": "array", 
          "items": { "$ref": "Faction" }
        },
        "skills": { 
          "type": "array", 
          "items": { "$ref": "Skill" }
        },
        "weapons": { 
          "type": "array", 
          "items": { "$ref": "Weapon" }
        },
        "summary": { "type": "string", "description": "A summary of the story." },
        "isDeleted": { "type": "boolean", "description": "Whether the story is in the recycle bin." },
        "deletedAt": { "type": "number", "description": "Timestamp when the story was deleted." },
        "isPinned": { "type": "boolean", "description": "Whether the story is pinned to the top." },
        "isPublished": { "type": "boolean" },
        "ownerId": { "type": "string", "description": "The UID of the user who owns this story." },
        "imageUrl": { "type": "string", "description": "Cover photo URL." }
      },
      "required": ["title", "lastModified", "ownerId"]
    },
    "Character": {
      "title": "Character",
      "description": "A character in a story.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "role": { "type": "string" },
        "description": { "type": "string" },
        "traits": { "type": "array", "items": { "type": "string" } },
        "isPinned": { "type": "boolean" },
        "gender": { "type": "string", "enum": ["male", "female", "other"] },
        "imageUrl": { "type": "string" }
      }
    },
    "Chapter": {
      "title": "Chapter",
      "description": "A chapter in a story.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "plotPoints": { "type": "array", "items": { "$ref": "PlotPoint" } },
        "order": { "type": "number" },
        "isDeleted": { "type": "boolean" },
        "deletedAt": { "type": "number" },
        "completions": { "type": "number" },
        "isPublished": { "type": "boolean" }
      }
    },
    "PlotPoint": {
      "title": "PlotPoint",
      "description": "A specific event or plot point in a chapter.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "isCompleted": { "type": "boolean" }
      }
    },
    "Creature": {
      "title": "Creature",
      "description": "A fantastical beast or creature.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "species": { "type": "string" },
        "habitat": { "type": "string" },
        "abilities": { "type": "string" },
        "threatLevel": { "type": "string", "enum": ["low", "medium", "high", "calamity"] },
        "description": { "type": "string" },
        "imageUrl": { "type": "string" }
      }
    },
    "Location": {
      "title": "Location",
      "description": "A geographic setting.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "climate": { "type": "string" },
        "rulingPower": { "type": "string" },
        "lore": { "type": "string" },
        "description": { "type": "string" },
        "imageUrl": { "type": "string" }
      }
    },
    "Faction": {
      "title": "Faction",
      "description": "A group or organization.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "leader": { "type": "string" },
        "influence": { "type": "string" },
        "alignment": { "type": "string", "enum": ["ally", "neutral", "enemy"] },
        "description": { "type": "string" },
        "imageUrl": { "type": "string" }
      }
    },
    "Skill": {
      "title": "Skill",
      "description": "A character skill.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "category": { "type": "string", "enum": ["Common", "Extra", "Unique", "Ultimate", "Ancient", "Legendary"] },
        "description": { "type": "string" },
        "imageUrl": { "type": "string" }
      }
    },
    "Weapon": {
      "title": "Weapon",
      "description": "A weapon or gear.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "rarity": { "type": "string", "enum": ["Common", "Rare", "Super Rare", "Legendary", "Mythical"] },
        "description": { "type": "string" },
        "imageUrl": { "type": "string" }
      }
    },
    "User": {
      "title": "User",
      "description": "User profile and settings.",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "user"] }
      }
    },
    "Suggestion": {
      "title": "Suggestion",
      "description": "A highlight and suggestion from a reader.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "storyId": { "type": "string" },
        "storyOwnerId": { "type": "string" },
        "chapterId": { "type": "string" },
        "readerId": { "type": "string" },
        "readerEmail": { "type": "string" },
        "selectedText": { "type": "string" },
        "suggestedText": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "accepted", "dismissed"] },
        "createdAt": { "type": "number" },
        "resolvedAt": { "type": "number" }
      },
      "required": ["storyId", "storyOwnerId", "chapterId", "readerId", "selectedText", "suggestedText", "status", "createdAt"]
    }
  },
  "firestore": {
    "stories": {
      "schema": "Story",
      "description": "Collection of stories/novels."
    },
    "users": {
      "schema": "User",
      "description": "Collection of user profiles."
    },
    "suggestions": {
      "schema": "Suggestion",
      "description": "Collection of highlights and suggestions."
    }
  }
}
